# 前端环境配置
# 数据库和管理系统认证后端接口
VITE_SERVER_API_ENDPOINT=http://localhost:5000/api
VITE_USE_LOCAL_STORAGE=true

BASE_URL=https://lyxyz5223.github.io/blog-ai/

# GitHub 评论配置 (Giscus)
# 仓库名称 (格式: 用户名/仓库名)
VITE_GITHUB_REPO=lyxyz5223/blog-ai
# 仓库 ID (从 Giscus 配置生成)
VITE_GITHUB_REPO_ID=R_kgDOR5BfjA
# Discussion 分类名称
VITE_GITHUB_DISCUSSION_CATEGORY=Comments
# Discussion 分类 ID (从 Giscus 配置生成)
VITE_GITHUB_DISCUSSION_CATEGORY_ID=DIC_kwDOR5BfjM4C6Btj
# 评论映射方式 (pathname | url | title | specific)
VITE_GITHUB_MAPPING=pathname
# 评论输入框位置 (top | bottom)
VITE_GITHUB_INPUT_POSITION=top
# 评论主题 (light | dark | preferred_color_scheme)
VITE_GITHUB_THEME=preferred_color_scheme

