# 前端环境配置示例
# 复制本文件为 .env.local 并填入实际的值

# API 端点
VITE_SERVER_API_ENDPOINT=http://localhost:5000/api

# 是否使用本地存储（开发时通常设为 false，使用后端 PostgreSQL）
VITE_USE_LOCAL_STORAGE=false


# 网站基础 URL（部署到 GitHub Pages 时需要设置），仅在VITE_USE_LOCAL_STORAGE=true时使用
BASE_URL=https://your-name.github.io/repo-name/

# ===== GitHub 评论配置 (Giscus) =====
# 详见: GITHUB_COMMENTS_QUICK_SETUP.md 或 GITHUB_COMMENTS_GUIDE.md

# 仓库名称 (格式: 用户名/仓库名)
# 示例: lyxyz5223/blog-ai
VITE_GITHUB_REPO=your-username/your-repo

# 仓库 ID (从 https://giscus.app 生成)
# 示例: R_kgDOR5BfjA
VITE_GITHUB_REPO_ID=R_kgDO...

# Discussion 分类名称 (建议使用: Comments)
VITE_GITHUB_DISCUSSION_CATEGORY=Comments

# Discussion 分类 ID (从 https://giscus.app 生成)
# 示例: DIC_kwDOR5BfjM4C6Btj
VITE_GITHUB_DISCUSSION_CATEGORY_ID=DIC_kwDO...

# 评论映射方式 (pathname | url | title | specific)
# pathname: 根据页面路径名 (推荐)
# url: 根据完整 URL
# title: 根据页面标题
# specific: 基于指定的 data-term 值
VITE_GITHUB_MAPPING=pathname

# 评论输入框位置 (top | bottom)
# top: 在评论列表上方
# bottom: 在评论列表下方 (默认)
VITE_GITHUB_INPUT_POSITION=top

# 评论主题 (light | dark | preferred_color_scheme)
# preferred_color_scheme: 自动根据系统主题 (推荐)
# light: 始终亮色模式
# dark: 始终深色模式
VITE_GITHUB_THEME=preferred_color_scheme